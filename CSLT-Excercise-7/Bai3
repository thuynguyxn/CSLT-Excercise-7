using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Bai3
{
    internal class Program
    {
        //to find the index of an array element.
        static int FindIndex(int[] arr, int value)
        {
            for (int i = 0; i < arr.Length; i++)
            {
                if (arr[i] == value) return i; // Trả về index đầu tiên tìm thấy
            }
            return -1; // Trả về -1 nếu không tìm thấy
        }
        static void Main(string[] args)
        {
            int[] randomArray = { 5, 12, 3, 19, 7, 12, 5, 2, 10, 14 };
            int target = 19;
            int index = FindIndex(randomArray, target);
            Console.WriteLine($"Index of {target}: {(index != -1 ? index.ToString() : "Not Found")}");
        }
    }
}
